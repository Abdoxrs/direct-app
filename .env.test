# ── App ──────────────────────────────────────────────
PORT=3001
BASE_URL=http://localhost:3001
NODE_ENV=test

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=test_jwt_secret
JWT_EXPIRES_IN=7d

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=snapurl_test
POSTGRES_USER=snapurl_user
POSTGRES_PASSWORD=supersecretpassword

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_TTL=3600

# ── Rate Limiting ────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=20